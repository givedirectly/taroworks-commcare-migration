<?xml version="1.0" encoding="UTF-8" ?>
<h:html xmlns:h="http://www.w3.org/1999/xhtml" xmlns:orx="http://openrosa.org/jr/xforms" xmlns="http://www.w3.org/2002/xforms" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:vellum="http://commcarehq.org/xforms/vellum">
	<h:head>
		<h:title>Survey</h:title>
		<model>
			<instance>
				<data xmlns:jrm="http://dev.commcarehq.org/jr/xforms" xmlns="http://openrosa.org/formdesigner/3B5D2FA0-D3BE-4DFC-A2F4-87DE19E788D0" uiVersion="1" version="1" name="Survey">
					<single_select />
					<calculation />
				</data>
			</instance>
			<bind vellum:nodeset="#form/single_select" nodeset="/data/single_select" />
			<bind vellum:nodeset="#form/calculation" nodeset="/data/calculation" vellum:calculate="if(#form/single_select = 'option_1', 'value', 'other')" calculate="if(/data/single_select = 'option_1', 'value', 'other')" />
			<itext>
				<translation lang="en" default="">
					<text id="single_select-label">
						<value>single select</value>
					</text>
					<text id="single_select-option_1-label">
						<value>option 1</value>
					</text>
					<text id="single_select-option_2-label">
						<value>option 2</value>
					</text>
				</translation>
			</itext>
		</model>
	</h:head>
	<h:body>
		<select1 vellum:ref="#form/single_select" ref="/data/single_select">
			<label ref="jr:itext('single_select-label')" />
			<item>
				<label ref="jr:itext('single_select-option_1-label')" />
				<value>option_1</value>
			</item>
			<item>
				<label ref="jr:itext('single_select-option_2-label')" />
				<value>option_2</value>
			</item>
		</select1>
	</h:body>
</h:html>