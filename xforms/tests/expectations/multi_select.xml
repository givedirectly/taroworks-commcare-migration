<?xml version="1.0" encoding="UTF-8" ?>
<h:html xmlns:h="http://www.w3.org/1999/xhtml" xmlns:orx="http://openrosa.org/jr/xforms" xmlns="http://www.w3.org/2002/xforms" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:vellum="http://commcarehq.org/xforms/vellum">
	<h:head>
		<h:title>Survey</h:title>
		<model>
			<instance>
				<data xmlns:jrm="http://dev.commcarehq.org/jr/xforms" xmlns="http://openrosa.org/formdesigner/3B5D2FA0-D3BE-4DFC-A2F4-87DE19E788D0" uiVersion="1" version="1" name="Survey">
					<multi_select />
				</data>
			</instance>
			<bind vellum:nodeset="#form/multi_select" nodeset="/data/multi_select" />
			<itext>
				<translation lang="en" default="">
					<text id="multi_select-label">
						<value>multi select</value>
					</text>
					<text id="multi_select-option_1-label">
						<value>option 1</value>
					</text>
					<text id="multi_select-option_2-label">
						<value>option 2</value>
					</text>
				</translation>
				<translation lang="art">
					<text id="multi_select-label">
						<value>multi select</value>
					</text>
					<text id="multi_select-option_1-label">
						<value>option 1</value>
					</text>
					<text id="multi_select-option_2-label">
						<value>option 2</value>
					</text>
				</translation>
			</itext>
		</model>
	</h:head>
	<h:body>
		<select vellum:ref="#form/multi_select" ref="/data/multi_select">
			<label ref="jr:itext('multi_select-label')" />
			<item>
				<label ref="jr:itext('multi_select-option_1-label')" />
				<value>option_1</value>
			</item>
			<item>
				<label ref="jr:itext('multi_select-option_2-label')" />
				<value>option_2</value>
			</item>
		</select>
	</h:body>
</h:html>