<?xml version="1.0" encoding="UTF-8" ?>
<h:html xmlns:h="http://www.w3.org/1999/xhtml" xmlns:orx="http://openrosa.org/jr/xforms" xmlns="http://www.w3.org/2002/xforms" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:vellum="http://commcarehq.org/xforms/vellum">
	<h:head>
		<h:title>Survey</h:title>
		<model>
			<instance>
				<data xmlns:jrm="http://dev.commcarehq.org/jr/xforms" xmlns="http://openrosa.org/formdesigner/3B5D2FA0-D3BE-4DFC-A2F4-87DE19E788D0" uiVersion="1" version="1" name="Survey">
					<text />
					<label_with_reference />
				</data>
			</instance>
			<bind vellum:nodeset="#form/text" nodeset="/data/text" type="xsd:string" />
			<bind vellum:nodeset="#form/label_with_reference" nodeset="/data/label_with_reference" />
			<itext>
				<translation lang="en" default="">
					<text id="text-label">
						<value>text</value>
					</text>
					<text id="label_with_reference-label">
						<value>text was: <output value="/data/text" vellum:value="#form/text" /></value>
					</text>
				</translation>
			</itext>
		</model>
	</h:head>
	<h:body>
		<input vellum:ref="#form/text" ref="/data/text">
			<label ref="jr:itext('text-label')" />
		</input>
		<trigger vellum:ref="#form/label_with_reference" ref="/data/label_with_reference" appearance="minimal">
			<label ref="jr:itext('label_with_reference-label')" />
		</trigger>
	</h:body>
</h:html>